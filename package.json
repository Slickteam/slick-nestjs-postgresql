    "typeorm": "0.3.28"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.16",
    "@slickteam/prettier": "2.0.3",
    "@trivago/prettier-plugin-sort-imports": "6.0.2",
    "@types/node": "24.10.12",
    "prettier": "3.8.1",
    "ts-loader": "9.5.4",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.9.3"
