  "keywords": [
    "Slickteam",
    "Nestjs",
    "Postgresql",
    "Typeorm"
  ],
  "license": "MIT",
  "author": {
    "email": "ronan.morel@slickteam.fr",
    "name": "Ronan MOREL",
