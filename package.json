  },
  "maintainers": [
    {
      "email": "ronan.morel@slickteam.fr",
      "name": "Ronan MOREL",
      "url": "https://slickteam.fr"
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Slickteam/slick-nestjs-postgresql.git"
  },
  "main": "dist/index.js",
